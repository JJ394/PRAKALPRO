jumlah_mk = int(input("Berapa jumlah mata kuliah? "))

total_bobot = 0

for i in range(1, jumlah_mk + 1):
    nilai = input(f"Nilai MK {i}: ").upper()
    
    if nilai == "A":
        bobot = 4
    elif nilai == "B":
        bobot = 3
    elif nilai == "C":
        bobot = 2
    elif nilai == "D":
        bobot = 1
    else:
        print("Nilai tidak valid! Dianggap D (bobot 1)")
        bobot = 1
    
    total_bobot = total_bobot + bobot

ips = total_bobot / jumlah_mk

print(f"Nilai IPS anda semester ini {ips:.2f}")

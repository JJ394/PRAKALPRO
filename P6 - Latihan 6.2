def ganjil(bawah, atas):
    if bawah < atas:
        print(f"bawah = {bawah}, atas = {atas}")
        print("Hasilnya:", end=" ")
        for i in range(bawah, atas + 1):
            if i % 2 != 0:
                print(i, end=" ")
    else:
        print(f"bawah = {bawah}, atas = {atas}")
        print("Hasilnya:", end=" ")
        for i in range(bawah, atas - 1, -1):
            if i % 2 != 0:
                print(i, end=" ")
    print()

bawah = int(input("Masukkan batas bawah: "))
atas = int(input("Masukkan batas atas: "))

ganjil(bawah, atas)
